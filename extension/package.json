{
  "name": "@f16/extension",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "F16 Maxance driver — Chrome MV3 extension that drives Ridaa's daily Chrome via vanilla DOM ops. V1 production driver per project_hosting_pivot.md.",
  "exports": {
    "./wire": {
      "types": "./src/wire.ts",
      "import": "./src/wire.ts"
    }
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.33.0"
  },
  "scripts": {
    "build": "tsc --noEmit -p tsconfig.json && node esbuild.config.mjs",
    "dev": "node esbuild.config.mjs --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint src tests --max-warnings 0"
  },
  "dependencies": {
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/chrome": "0.0.288",
    "@types/node": "25.8.0",
    "esbuild": "0.28.0",
    "typescript": "6.0.3",
    "vitest": "4.1.6"
  }
}
