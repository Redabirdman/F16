# F16 admin — environment template.
# Vite only exposes vars prefixed with VITE_ to the client bundle.
# Copy to .env.local for local dev; never commit .env files.

# Backend HTTP base URL (Hono server)
VITE_API_BASE_URL=http://localhost:3001

# Backend WebSocket URL (for realtime updates, team-chat mirror, etc.)
VITE_WS_URL=ws://localhost:3001
