{
  "name": "@f16/backend",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.33.0"
  },
  "main": "dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "pretest": "tsc --noEmit -p tsconfig.test.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint src tests --max-warnings 0",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "seed:dev": "tsx scripts/seed-dev.ts",
    "seed:dev:confirm": "tsx scripts/seed-dev.ts --yes",
    "test:e2e:db": "vitest run tests/e2e"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.96.0",
    "@hono/node-server": "2.0.2",
    "bullmq": "5.76.9",
    "dotenv-safe": "9.1.0",
    "drizzle-orm": "0.45.2",
    "hono": "4.12.19",
    "ioredis": "5.10.1",
    "marked": "^18.0.3",
    "nodemailer": "^8.0.7",
    "pino": "10.3.1",
    "postgres": "3.4.9",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "25.8.0",
    "@types/nodemailer": "^8.0.0",
    "drizzle-kit": "0.31.10",
    "pino-pretty": "13.1.3",
    "tsx": "4.22.0",
    "typescript": "6.0.3",
    "vitest": "4.1.6"
  }
}
