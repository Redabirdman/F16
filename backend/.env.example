# f16-backend environment template — copy to `.env` and fill in real values.
# `.env` itself is gitignored. Never commit secrets.

# ---- Runtime ----------------------------------------------------------------
# Node runtime mode. One of: development | test | production
NODE_ENV=development
# HTTP port the Hono server binds to.
PORT=3001
# Pino log level. One of: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# ---- Datastores -------------------------------------------------------------
# Postgres connection string (pgvector extension required). Used by Drizzle.
DATABASE_URL=postgres://f16:f16@localhost:5432/f16
# Redis connection string. Used by BullMQ + ioredis for the agent dispatcher.
REDIS_URL=redis://localhost:6379

# ---- LLM providers ----------------------------------------------------------
# Anthropic API key for the Claude Agent SDK.
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
# OpenRouter API key (fallback / cheaper model routing).
OPENROUTER_API_KEY=sk-or-REPLACE_ME

# ---- Encryption / signing ---------------------------------------------------
# 32-byte base64 key for envelope-encrypting PII at rest. Rotate per playbook.
PII_ENCRYPTION_KEY=REPLACE_ME_BASE64_32_BYTES
# Shared secret used to sign + verify inbound webhook payloads (HMAC-SHA256).
HMAC_WEBHOOK_SECRET=REPLACE_ME_RANDOM_64_HEX

# ---- WhatsApp (WAHA) --------------------------------------------------------
# Base URL of the self-hosted WAHA instance.
WAHA_BASE_URL=http://localhost:3000
# WAHA admin API key.
WAHA_API_KEY=REPLACE_ME
