# =============================================================================
# F16 — Consolidated environment template (REFERENCE)
# =============================================================================
#
# This is a single quick-reference document listing EVERY env var consumed by
# any F16 service. It is the checklist Ridaa uses when populating EasyPanel
# app env in production.
#
# Per-service env templates remain canonical for what each container actually
# needs (see backend/.env.template, admin/.env.template, pipecat/.env.template,
# stagehand/.env.template). This file is the union of all of them, grouped by
# concern instead of by service.
#
# Markers:
#   [SECRET] — never log, never commit, store in a password manager + EasyPanel
#   [CONFIG] — non-sensitive; safe to commit example values
#
# See `docs/runbooks/secrets.md` for who holds which secret, rotation cadence,
# and the EasyPanel setup checklist.
# =============================================================================


# -----------------------------------------------------------------------------
# 1. Shared / global
# -----------------------------------------------------------------------------
# [CONFIG] Environment tier — drives log level defaults, error verbosity, and
#          per-service feature flags. One of: development | staging | production
F16_ENV=development
# [CONFIG] Unique per-deployment identifier; included on every log line for
#          cross-service correlation. Set per EasyPanel project (e.g. f16-prod-1).
F16_INSTANCE_ID=f16-local
# [CONFIG] Internal DNS URL of the backend on the EasyPanel project network.
#          Used by pipecat + stagehand to POST callbacks. In dev: http://localhost:3001
F16_BACKEND_URL=http://f16-backend:3001
# [CONFIG] Internal DNS URL of the pipecat voice bridge. Used by backend to
#          dispatch outbound voice tasks.
F16_PIPECAT_URL=http://f16-pipecat:8000
# [CONFIG] Internal DNS URL of the stagehand browser service. Used by backend
#          to dispatch browser-automation intents (e.g. Maxance flows).
F16_STAGEHAND_URL=http://f16-stagehand:4001
# [CONFIG] Pino / Python logging level. One of: trace | debug | info | warn | error | fatal
LOG_LEVEL=info


# -----------------------------------------------------------------------------
# 2. Database (Postgres + pgvector)
# -----------------------------------------------------------------------------
# [SECRET] Postgres connection string (pgvector + pgcrypto required). Consumed
#          by backend via Drizzle. Hostname is the EasyPanel app name in prod.
DATABASE_URL=postgres://f16:f16@f16-postgres:5432/f16


# -----------------------------------------------------------------------------
# 3. Cache / Queue (Redis)
# -----------------------------------------------------------------------------
# [SECRET] Redis connection string. Used by BullMQ (backend) and the agent
#          dispatcher. Hostname is the EasyPanel app name in prod.
REDIS_URL=redis://f16-redis:6379


# -----------------------------------------------------------------------------
# 4. LLM providers (Anthropic + OpenRouter)
# -----------------------------------------------------------------------------
# [SECRET] Anthropic API key for the Claude Agent SDK. Issued at
#          console.anthropic.com — cap monthly spend at €1k (M0.T2).
#          Consumed by: backend, stagehand.
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
# [SECRET] OpenRouter API key (fallback + cheaper-model routing).
#          Consumed by: backend.
OPENROUTER_API_KEY=sk-or-REPLACE_ME
# [CONFIG] Stagehand vision-model selector. Defaults to Sonnet 4.6; bump to
#          claude-opus-4-7 if selector resolution starts missing.
STAGEHAND_LLM_MODEL=claude-sonnet-4-6


# -----------------------------------------------------------------------------
# 5. WhatsApp (WAHA — already deployed on the VPS)
# -----------------------------------------------------------------------------
# [CONFIG] Base URL of the self-hosted WAHA instance (internal DNS in prod).
WAHA_BASE_URL=http://waha:3000
# [SECRET] WAHA admin API key (issued in the WAHA dashboard).
WAHA_API_KEY=REPLACE_ME


# -----------------------------------------------------------------------------
# 6. Voice (OVH SIP + Deepgram + Azure)
# -----------------------------------------------------------------------------
# [SECRET] OVH SIP trunk username. Provisioned in the OVH telephony console.
OVH_SIP_USERNAME=REPLACE_ME
# [SECRET] OVH SIP trunk password.
OVH_SIP_PASSWORD=REPLACE_ME
# [CONFIG] OVH SIP registrar hostname.
OVH_SIP_DOMAIN=sip.ovh.fr
# [CONFIG] Public DID (E.164) — the number customers actually dial.
OVH_SIP_DID=REPLACE_ME
# [SECRET] Deepgram API key. Use the French model (`nova-2-general`, `language=fr`).
DEEPGRAM_API_KEY=REPLACE_ME
# [SECRET] Azure Cognitive Services Speech key (TTS). Use a French neural voice
#          (e.g. `fr-FR-DeniseNeural`).
AZURE_SPEECH_KEY=REPLACE_ME
# [CONFIG] Azure region for the Speech resource.
AZURE_SPEECH_REGION=westeurope


# -----------------------------------------------------------------------------
# 7. Email (BillionMail)
# -----------------------------------------------------------------------------
# [CONFIG] SMTP relay host (internal DNS to f16-billionmail in prod).
BILLIONMAIL_SMTP_HOST=f16-billionmail
# [CONFIG] SMTP submission port. Use 587 for STARTTLS, 465 for implicit TLS.
BILLIONMAIL_SMTP_PORT=587
# [SECRET] SMTP auth username.
BILLIONMAIL_SMTP_USERNAME=REPLACE_ME
# [SECRET] SMTP auth password.
BILLIONMAIL_SMTP_PASSWORD=REPLACE_ME
# [CONFIG] Default From: address for outbound mail.
BILLIONMAIL_FROM_ADDRESS=noreply@assuryalconseil.fr
# [SECRET] DKIM private key (PEM) — used by BillionMail to sign outbound mail.
BILLIONMAIL_DKIM_PRIVATE_KEY=REPLACE_ME


# -----------------------------------------------------------------------------
# 8. SMS (android-sms-gateway)
# -----------------------------------------------------------------------------
# [CONFIG] Base URL of the android-sms-gateway instance.
SMS_GATEWAY_BASE_URL=REPLACE_ME
# [SECRET] Gateway username (HTTP basic auth).
SMS_GATEWAY_USERNAME=REPLACE_ME
# [SECRET] Gateway password.
SMS_GATEWAY_PASSWORD=REPLACE_ME


# -----------------------------------------------------------------------------
# 9. Browser (Stagehand + Maxance)
# -----------------------------------------------------------------------------
# [CONFIG] Run Chromium headless. Set false locally to watch a real window.
STAGEHAND_BROWSER_HEADLESS=true
# [CONFIG] Per-action browser timeout in ms.
STAGEHAND_BROWSER_TIMEOUT_MS=30000
# [CONFIG] Base URL of the Maxance insurance webapp (provided by Ridaa in M0.T6).
MAXANCE_BASE_URL=https://maxance.example.com
# [SECRET] Maxance login username (only read inside the M8 login flow).
MAXANCE_USERNAME=REPLACE_ME
# [SECRET] Maxance login password (only read inside the M8 login flow).
MAXANCE_PASSWORD=REPLACE_ME


# -----------------------------------------------------------------------------
# 10. Ads (Meta Marketing API)
# -----------------------------------------------------------------------------
# [SECRET] Long-lived Meta access token (system user). Issued at business.facebook.com.
META_ACCESS_TOKEN=REPLACE_ME
# [CONFIG] Meta ad-account ID (`act_<digits>`).
META_AD_ACCOUNT_ID=act_REPLACE_ME
# [SECRET] Meta App secret (used to verify webhook signatures).
META_APP_SECRET=REPLACE_ME


# -----------------------------------------------------------------------------
# 11. CRM (HubSpot)
# -----------------------------------------------------------------------------
# [SECRET] HubSpot private-app access token. Issued in HubSpot → Settings → Integrations.
HUBSPOT_ACCESS_TOKEN=REPLACE_ME
# [CONFIG] HubSpot portal (hub) ID.
HUBSPOT_PORTAL_ID=REPLACE_ME


# -----------------------------------------------------------------------------
# 12. Encryption (PII at rest)
# -----------------------------------------------------------------------------
# [SECRET] 32-byte (base64-encoded) symmetric key for envelope-encrypting PII
#          at rest. Generate with: openssl rand -base64 32
#          Single shared value across backend + stagehand. Rotate per playbook.
PII_ENCRYPTION_KEY=REPLACE_ME_BASE64_32_BYTES


# -----------------------------------------------------------------------------
# 13. Webhook signing (HMAC secrets)
# -----------------------------------------------------------------------------
# [SECRET] Shared secret used to sign/verify the public lead-intake webhook
#          (HMAC-SHA256). Generate with: openssl rand -hex 32
HMAC_WEBHOOK_SECRET=REPLACE_ME_RANDOM_64_HEX


# -----------------------------------------------------------------------------
# 14. Observability (Loki + Grafana)
# -----------------------------------------------------------------------------
# [CONFIG] Loki push endpoint (HTTP). All services ship structured logs here.
LOKI_PUSH_URL=http://loki:3100/loki/api/v1/push
# [SECRET] Loki HTTP basic-auth credentials (`user:password`) if Loki is fronted
#          by Caddy basic-auth. Leave blank for open intra-VPS Loki.
LOKI_BASIC_AUTH=
# [CONFIG] Grafana public URL — only used in alert messages, not for ingestion.
GRAFANA_URL=https://grafana.example.com
# [SECRET] Grafana admin password (initial). Rotate after first login.
GRAFANA_ADMIN_PASSWORD=REPLACE_ME


# -----------------------------------------------------------------------------
# 15. Admin auth (JWT + magic-link sender)
# -----------------------------------------------------------------------------
# [SECRET] HMAC secret used to sign admin-panel JWT session tokens.
#          Generate with: openssl rand -hex 64
ADMIN_JWT_SECRET=REPLACE_ME_RANDOM_128_HEX
# [CONFIG] JWT TTL in seconds (default 12h).
ADMIN_JWT_TTL_SECONDS=43200
# [CONFIG] From: address used for admin magic-link emails. Must be a domain
#          BillionMail is authorised to send for (SPF + DKIM aligned).
ADMIN_MAGIC_LINK_FROM=admin@assuryalconseil.fr


# =============================================================================
# Reminders
# =============================================================================
# - This file is a REFERENCE. Actual per-service env values live in EasyPanel
#   container env (prod) or per-workspace local `.env` files (dev). Local
#   `.env` files are gitignored.
# - Never commit a populated `.env`. Never paste secrets in chat / WhatsApp /
#   Slack / email.
# - See `docs/runbooks/secrets.md` for who holds which secret, rotation
#   cadence, and the EasyPanel app-by-app setup checklist.
# =============================================================================
