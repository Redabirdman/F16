# F16 Pipecat bridge — environment template.
# Copy to `.env` (gitignored) and fill in real values.
# NONE of these are required for `/health` to respond. They are
# consumed once the voice pipeline is wired in milestone M10.

# -------- Speech (Deepgram) — STT *and* TTS --------
# Required in M10. ONE key powers BOTH:
#   * STT: Deepgram Nova-3, language=fr  (French streaming transcription)
#   * TTS: Deepgram Aura-2 French voice  (default speech synthesis)
# Ridaa consolidated on Deepgram for billing simplicity; see TTS_PROVIDER below.
DEEPGRAM_API_KEY=

# Which TTS engine to speak with: "deepgram" (default) | "azure".
# Deepgram Aura-2 FR is primary; Azure Neural FR is FALLBACK only.
TTS_PROVIDER=deepgram

# -------- Text-to-speech (Azure Neural) — FALLBACK ONLY --------
# Only consumed when TTS_PROVIDER=azure. Use a French neural voice
# (default `fr-FR-DeniseNeural`). Leave blank when using Deepgram TTS.
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=westeurope

# -------- F16 backend (voice brain) --------
# Required in M10. Origin of the frozen voice turn endpoint:
#   POST {F16_BACKEND_BASE_URL}/v1/voice/turn
# Pipecat is a thin bridge — all prompts/logic live behind this URL.
F16_BACKEND_BASE_URL=http://backend:3001

# Shared secret sent on every backend turn call. Header defaults to
# `X-F16-Webhook-Secret`; override the header NAME with
# F16_WEBHOOK_SECRET_HEADER if the backend enforces a different one.
F16_WEBHOOK_SECRET=
# F16_WEBHOOK_SECRET_HEADER=X-F16-Webhook-Secret

# -------- OVH SIP trunk --------
# Required in M10. DID is the public number customers dial.
OVH_SIP_USERNAME=
OVH_SIP_PASSWORD=
OVH_SIP_DOMAIN=sip.ovh.fr
OVH_SIP_DID=

# -------- Observability --------
LOG_LEVEL=INFO
# Asterisk AudioSocket bridge (M10): Pipecat TCP server bind host + port
AUDIOSOCKET_HOST=0.0.0.0
AUDIOSOCKET_PORT=9092
# shared secret for GET /v1/voice/session/:id (must match backend)
F16_SESSION_LOOKUP_SECRET=
