# F16 Pipecat bridge — environment template.
# Copy to `.env` (gitignored) and fill in real values.
# NONE of these are required for `/health` to respond. They are
# consumed once the voice pipeline is wired in milestone M10.

# -------- Speech-to-text (Deepgram) --------
# Required in M10. French model (`nova-2-general` + `language=fr`).
DEEPGRAM_API_KEY=

# -------- Text-to-speech (Azure Neural) --------
# Required in M10. Use a French neural voice (e.g. `fr-FR-DeniseNeural`).
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=westeurope

# -------- F16 backend --------
# Required in M10. Where to POST `/v1/sales-agent/turn`.
F16_BACKEND_URL=http://backend:3001

# -------- OVH SIP trunk --------
# Required in M10. DID is the public number customers dial.
OVH_SIP_USERNAME=
OVH_SIP_PASSWORD=
OVH_SIP_DOMAIN=sip.ovh.fr
OVH_SIP_DID=

# -------- Observability --------
LOG_LEVEL=INFO
