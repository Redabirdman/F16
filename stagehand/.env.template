# @f16/stagehand — environment template
# Copy to .env and fill values. dotenv-safe enforces every key listed here is set.

# ── Runtime ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4001
LOG_LEVEL=debug

# ── Browser / Stagehand ──────────────────────────────────────────────────────
# Set to false locally to watch a real Chromium window while iterating on intents.
STAGEHAND_BROWSER_HEADLESS=true
STAGEHAND_BROWSER_TIMEOUT_MS=30000

# Stagehand uses Claude vision + DOM to resolve high-level intents to selectors.
# Same Anthropic key the backend uses — keep it scoped, never log it.
ANTHROPIC_API_KEY=
# Current Sonnet (4.6). Opus 4.7 (claude-opus-4-7) is also valid here if
# Stagehand's vision-driven selector resolution needs the stronger model.
STAGEHAND_LLM_MODEL=claude-sonnet-4-6

# ── Maxance insurance webapp ────────────────────────────────────────────────
# Broker portal entry point. Real value lives in .env, never in .env.template.
MAXANCE_BASE_URL=https://extranet.maxance.com/MaXance/
# Credentials are only read inside the M8 login flow. NEVER log either of these.
# Fill in .env (gitignored). Placeholders here so dotenv-safe passes on dev machines.
MAXANCE_USERNAME=<broker-identifier>
MAXANCE_PASSWORD=<broker-password>

# M8.T2 live test gate. Empty/unset → unit + HTTP tests only. Set to "1" to
# enable the single live test that hits the real Maxance portal (opt-in,
# never in CI; see stagehand/src/maxance/index.ts for run instructions).
MAXANCE_LIVE=

# ── F16 backend ──────────────────────────────────────────────────────────────
# Used for callbacks (e.g. delivering captured screenshots/prices back to the
# Maxance Operator agent). In docker-compose, use the service hostname.
F16_BACKEND_URL=http://backend:3001
